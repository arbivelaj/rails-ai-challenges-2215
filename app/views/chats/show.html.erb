<%= link_to "← #{@chat.challenge.name}", challenge_path(@chat.challenge) %>

<h1 id="chat_title"><%= @chat.title %></h1>

<div id="messages">
  <%= render "messages/messages", messages: @chat.messages  %>
</div>

<div id="new_message_container">
  <%= render "messages/form", message: @message, chat: @chat %>
</div>
